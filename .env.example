# PredictWaves — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real keys.

# ─────────────────────────────────────────────────────────────────────────────
# Next
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Privy (privy.io → your app → Settings → API keys)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Alchemy (alchemy.com → your Polygon Mainnet app → API key)
# Paste the full HTTPS URL, not just the key
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
ALCHEMY_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Polymarket (apply at polymarket.com developer portal — Phase 4 only)
# Leave blank for now; read-only endpoints are public.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POLYMARKET_CHAIN_ID=137
# Polymarket Relayer API key (authorizes gasless wallet setup) — server-side only.
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
# Builder code attached to orders for revenue attribution.
POLYMARKET_BUILDER_CODE=
# Privy authorization key for delegated wallet signing (optional until Delegated
# Actions / authorization keys are configured in the Privy dashboard).
PRIVY_AUTHORIZATION_KEY=
# AES-256-GCM key (32 random bytes, hex) for encrypting per-user CLOB creds at rest.
# Generate with: openssl rand -hex 32
CLOB_CREDS_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (supabase.com → your project → Settings → API)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# FX source (CoinGecko free, no key needed)
# ─────────────────────────────────────────────────────────────────────────────
FX_SOURCE_URL=https://api.coingecko.com/api/v3/simple/price?ids=tether&vs_currencies=ngn
FX_CACHE_TTL_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────
# Sentry (sentry.io — Phase 7, leave blank for now)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─────────────────────────────────────────────────────────────────────────────
# PostHog (posthog.com — Phase 7, leave blank for now)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─────────────────────────────────────────────────────────────────────────────
# Resend (resend.com — Phase 7, leave blank for now)
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Support contact
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_SUPPORT_EMAIL=support@predictwaves.com
